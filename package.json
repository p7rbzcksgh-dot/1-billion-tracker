{
  "name": "tcg-one-billion-monitor",
  "version": "1.2.0",
  "private": true,
  "description": "TCG Machines live Cards PhyzBatched monitor with a one-time 1 billion card email alert.",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "install-browser": "playwright install chromium",
    "verify": "node verify.js",
    "test": "node --test test-*.js",
    "smoke": "node smoke.js",
    "check": "npm run verify && npm test && npm run smoke"
  },
  "dependencies": {
    "dotenv": "17.3.1",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "nodemailer": "7.0.3",
    "playwright": "1.53.0",
    "ws": "8.18.3"
  }
}
